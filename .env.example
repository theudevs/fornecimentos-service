SERVICE_NAME=fornecimentos-service
PORT=5003
APP_ENV=local

# Use o usuario de aplicacao. Ele tem permissao de DML, mas nao de DDL.
DATABASE_URL=postgresql://svc_portal_b2b:SENHA_AQUI@136.114.235.212:5432/portal_b2b
DB_SCHEMA=portal_b2b

# Para teste local rodando a API direto no Windows, troque temporariamente pelos dados do seu PostgreSQL local:
# DATABASE_URL=postgresql://USUARIO_LOCAL:SENHA_LOCAL@localhost:5432/portal_b2b

# Para teste local rodando a API em Docker e acessando PostgreSQL instalado no Windows:
# DATABASE_URL=postgresql://USUARIO_LOCAL:SENHA_LOCAL@host.docker.internal:5432/portal_b2b

# Para desenvolvimento local sem Kafka/JWT, altere temporariamente para false.
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=10.128.0.2:9092,10.128.0.3:9092,10.128.0.4:9092
KAFKA_FAIL_ON_PUBLISH_ERROR=false

# Autenticacao. Para desenvolvimento local sem JWT, altere temporariamente para false.
# Na integracao, mantenha true e configure o segredo compartilhado fora do Git.
AUTH_ENABLED=true
JWT_SECRET=SUBSTITUIR_PELA_CHAVE_COMPARTILHADA
JWT_ISSUER=portal-autenticacao
JWT_AUDIENCE=portal-b2b
JWT_CLOCK_SKEW_SECONDS=60
