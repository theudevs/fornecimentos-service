APP_NAME=fornecimentos-service
APP_ENV=local

# Use o usuario de aplicacao. Ele tem permissao de DML, mas nao de DDL.
DATABASE_URL=postgresql+psycopg2://USUARIO:SENHA@HOST:5432/portal_b2b

# Para teste local, troque temporariamente pelos dados do seu PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://USUARIO_LOCAL:SENHA_LOCAL@localhost:5432/portal_b2b

# Kafka pode ficar desligado enquanto voce testa o CRUD localmente.
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_FORNECIMENTOS=portal-b2b.fornecimentos
